{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "JWT_SECRET",
    "APPWRITE_API_KEY",
    "GOOGLE_CLIENT_SECRET",
    "STRIPE_SECRET_KEY",
    "GEMINI_API_KEY",
    "INNGEST_EVENT_KEY",
    "INNGEST_SIGNING_KEY",
    "INNGEST_DEV",
    "INNGEST_SERVE_ORIGIN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "format": {},
    "format:fix": {
      "cache": false
    }
  }
}

